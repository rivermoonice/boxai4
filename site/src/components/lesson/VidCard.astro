---
/**
 * VidCard — click-to-play YouTube placeholder.
 *
 * Renders a thumbnail (`i.ytimg.com/vi/<id>/hqdefault.jpg`) with a centered
 * play button. The actual <iframe> is mounted on click only, so the page
 * doesn't load third-party JS until the user opts in.
 *
 * Usage in MDX:
 *   <VidCard id="GGtmmx0MKCI" title="Agent Harness vs Coding Harness" />
 *   <VidCard id="..." title="..." start={90} />
 */
interface Props {
  id: string;
  title: string;
  start?: number;
}
const { id, title, start = 0 } = Astro.props;
const thumb = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const embed = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&start=${start}&rel=0`;
---
<div
  class="vidcard"
  data-vidcard
  data-embed={embed}
  role="figure"
  aria-label={`YouTube video: ${title}`}
>
  <button type="button" class="vidcard__btn" aria-label={`Play ${title}`}>
    <img class="vidcard__thumb" src={thumb} alt="" loading="lazy" />
    <span class="vidcard__play" aria-hidden="true">
      <svg width="68" height="48" viewBox="0 0 68 48">
        <path d="M66.52 7.74A8 8 0 0 0 60.34 1.5C54.61 0 34 0 34 0S13.39 0 7.66 1.5A8 8 0 0 0 1.48 7.74 83.6 83.6 0 0 0 0 24a83.6 83.6 0 0 0 1.48 16.26 8 8 0 0 0 6.18 6.24C13.39 48 34 48 34 48s20.61 0 26.34-1.5a8 8 0 0 0 6.18-6.24A83.6 83.6 0 0 0 68 24a83.6 83.6 0 0 0-1.48-16.26z" fill="#f00" fill-opacity="0.85"/>
        <path d="M27 34V14l18 10z" fill="#fff"/>
      </svg>
    </span>
    <span class="vidcard__title">{title}</span>
  </button>
</div>

<style>
  .vidcard {
    margin: var(--sp-5) 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .vidcard__btn {
    all: unset;
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    cursor: pointer;
    background: #000;
  }
  .vidcard__btn:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }
  .vidcard__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }
  .vidcard__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
    transition: transform 0.15s ease;
  }
  .vidcard__btn:hover .vidcard__play { transform: scale(1.08); }
  .vidcard__title {
    position: absolute;
    left: var(--sp-3);
    right: var(--sp-3);
    bottom: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    font-size: var(--fs-sm);
    font-weight: 500;
    border-radius: var(--radius-sm);
    line-height: 1.3;
  }
</style>

<script>
  function initVidCards() {
    document.querySelectorAll<HTMLElement>('[data-vidcard]').forEach((card) => {
      const btn = card.querySelector<HTMLButtonElement>('.vidcard__btn');
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const embed = card.dataset.embed;
        if (!embed) return;
        const iframe = document.createElement('iframe');
        iframe.src = embed;
        iframe.title = card.getAttribute('aria-label') ?? 'Embedded video';
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.style.cssText = 'width:100%;aspect-ratio:16/9;border:0;display:block;';
        card.replaceWith(iframe);
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVidCards);
  } else {
    initVidCards();
  }
</script>
