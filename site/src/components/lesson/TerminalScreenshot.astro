---
/**
 * TerminalScreenshot — styled terminal-window wrapper around an optimized
 * Hermes CLI screenshot.
 *
 * Uses Astro's <Image> from astro:assets for built-in optimization
 * (Vite hashes the asset, emits AVIF/WebP variants, infers width/height).
 * Sharp is the underlying image service.
 *
 * Usage in MDX:
 *   ---
 *   import hermesHelp from '../../../assets/lessons/hermes/L01/hermes-help.png';
 *   ---
 *   <TerminalScreenshot
 *     image={hermesHelp}
 *     title="hermes --help"
 *     alt="Output of the hermes --help command"
 *   />
 *
 * Optional props:
 *   - caption: shown below the figure.
 *   - loading: 'lazy' (default) | 'eager'.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  title?: string;
  alt: string;
  caption?: string;
  loading?: 'lazy' | 'eager';
}
const { image, title, alt, caption, loading = 'lazy' } = Astro.props;
---
<figure class="term">
  <div class="term__chrome" role="presentation">
    <span class="term__dot term__dot--r" aria-hidden="true"></span>
    <span class="term__dot term__dot--y" aria-hidden="true"></span>
    <span class="term__dot term__dot--g" aria-hidden="true"></span>
    {title && <span class="term__title">{title}</span>}
  </div>
  <Image
    src={image}
    alt={alt}
    loading={loading}
    decoding="async"
    widths={[480, 800, 1200]}
    sizes="(max-width: 880px) 100vw, 800px"
    format="webp"
    quality={80}
    class="term__img"
  />
  {caption && <figcaption class="term__caption">{caption}</figcaption>}
</figure>

<style>
  .term {
    margin: var(--sp-5) 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #0d1117;
  }
  .term__chrome {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 10px 14px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }
  .term__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .term__dot--r { background: #ff5f57; }
  .term__dot--y { background: #febc2e; }
  .term__dot--g { background: #28c840; }
  .term__title {
    flex: 1;
    text-align: center;
    color: #8b949e;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    font-size: 12px;
    letter-spacing: 0.02em;
  }
  .term__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }
  .term__caption {
    padding: var(--sp-2) var(--sp-4);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    text-align: center;
    background: #161b22;
    border-top: 1px solid #30363d;
  }
</style>
