---
/**
 * LessonCard — used in module landing pages and the /lessons/ index.
 * Renders as a linkable card with order number, title, summary, time, and date.
 */
interface Props {
  order: number;
  title: string;
  summary: string;
  href: string;
  readingMinutes: number;
  updatedDate: Date;
  accent: string;
}

const { order, title, summary, href, readingMinutes, updatedDate, accent } = Astro.props;
const updatedLabel = updatedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<a class="lesson-card" href={href} style={`--accent: ${accent}`}>
  <span class="lesson-card__order" aria-hidden="true">L{String(order).padStart(2, '0')}</span>
  <div class="lesson-card__body">
    <h3 class="lesson-card__title">{title}</h3>
    {summary && <p class="lesson-card__summary">{summary}</p>}
    <p class="lesson-card__meta">
      <span>{readingMinutes} min read</span>
      <span aria-hidden="true">·</span>
      <span>Updated {updatedLabel}</span>
    </p>
  </div>
  <span class="lesson-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .lesson-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--sp-4);
    align-items: start;
    padding: var(--sp-4) var(--sp-5);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--fg);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    position: relative;
    overflow: hidden;
  }
  .lesson-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--accent);
    opacity: 0.6;
    transition: opacity 0.15s ease;
  }
  .lesson-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
  }
  .lesson-card:hover::before { opacity: 1; }

  .lesson-card__order {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--accent);
    padding-top: 2px;
    letter-spacing: 0.02em;
  }
  .lesson-card__title {
    font-size: var(--fs-lg);
    margin: 0 0 var(--sp-2);
    line-height: 1.3;
  }
  .lesson-card__summary {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    margin: 0 0 var(--sp-2);
    line-height: 1.5;
  }
  .lesson-card__meta {
    color: var(--fg-subtle);
    font-size: var(--fs-xs);
    display: flex;
    gap: var(--sp-2);
    margin: 0;
  }
  .lesson-card__arrow {
    color: var(--fg-subtle);
    align-self: center;
    transition: transform 0.15s ease, color 0.15s ease;
  }
  .lesson-card:hover .lesson-card__arrow {
    color: var(--fg);
    transform: translateX(2px);
  }

  @media (max-width: 600px) {
    .lesson-card {
      grid-template-columns: auto 1fr;
    }
    .lesson-card__arrow {
      grid-column: 2;
      justify-self: end;
    }
  }
</style>