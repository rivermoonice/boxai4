---
/**
 * Nav — top navigation bar with theme toggle.
 *
 * Sticky at the top of the viewport. Three primary links:
 * Lessons (with module dropdown), About, Docs. The theme toggle flips
 * between light and dark and persists in localStorage.
 */
---
<header class="nav">
  <div class="nav__inner container">
    <a class="nav__brand" href="/">
      <span class="nav__brand-mark" aria-hidden="true">◆</span>
      <span class="nav__brand-text">Boxmining AI Academy</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      <a href="/lessons/">Lessons</a>
      <a href="/about/">About</a>
      <a href="/specs/lesson-spec/">Spec</a>
      <a href="https://github.com/rivermoonice/boxai4" rel="noopener external">GitHub ↗</a>
    </nav>
    <button class="nav__theme" type="button" aria-label="Toggle dark mode" data-theme-toggle>
      <svg class="nav__theme-icon nav__theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
      </svg>
      <svg class="nav__theme-icon nav__theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    height: var(--nav-height);
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--fg);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .nav__brand-mark {
    color: var(--link);
    font-size: 1.1em;
  }
  .nav__brand-text { font-size: var(--fs-md); }

  .nav__links {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .nav__links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    padding: var(--sp-2) var(--sp-1);
    transition: color 0.15s ease;
  }
  .nav__links a:hover { color: var(--fg); }

  .nav__theme {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .nav__theme:hover {
    color: var(--fg);
    border-color: var(--border-strong);
    background: var(--bg-elev);
  }
  .nav__theme-icon { display: none; }
  :root[data-theme="dark"] .nav__theme-icon--sun { display: block; }
  :root:not([data-theme="dark"]) .nav__theme-icon--moon { display: block; }

  @media (max-width: 720px) {
    .nav__links a:not([href*="github"]) { display: none; }
    .nav__brand-text { display: none; }
  }
</style>

<script>
  // Theme toggle handler. Idempotent — multiple toggles on the same button
  // are safe.
  function initTheme() {
    const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme;
      const isDark = current === 'dark' ||
        (!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
      const next = isDark ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (_) {}
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTheme);
  } else {
    initTheme();
  }
</script>